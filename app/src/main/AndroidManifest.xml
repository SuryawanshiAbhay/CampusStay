<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet Permission for Firebase -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="CampusStay"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.CampusStay">

        <!-- Launcher Activity -->
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <!-- OTP Authentication -->
        <activity android:name=".SendOtpActivity"/>
        <activity android:name=".VerifyOtpActivity"/>

        <!-- Owner Section -->
        <activity android:name=".OwnerHomeActivity"/>
        <activity android:name=".OwnerAddHostelActivity"/>
        <activity android:name=".OwnerProfileActivity"/>

        <!-- Student Section -->
        <activity android:name=".StudentHomeActivity"/>
        <activity android:name=".StudentProfileActivity"/>

        <!-- Hostel List -->
        <activity android:name=".HostelListActivity"/>

    </application>

</manifest>